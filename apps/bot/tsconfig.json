{
	"extends": ["@sapphire/ts-config", "@sapphire/ts-config/extra-strict", "@sapphire/ts-config/decorators"],
	"compilerOptions": {
		"noEmit": true,
		"incremental": false,
		"skipLibCheck": false,
		"allowImportingTsExtensions": true,
		"typeRoots": ["./src/types", "node_modules/@types"]
	},
	"include": ["src/**/*", "src/types/**/*"]
}
