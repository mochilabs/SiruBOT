{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
      "build": {
        "dependsOn": ["^lint:fix", "^typecheck", "^build"],
        "outputs": ["dist/**", ".next/**", "!dist/**/*.map"]
      },
      "generate": {
        "outputs": ["dist/**"]
      },
      "dev": {
        "cache": false,
        "persistent": true
      },
      "watch": {
        "dependsOn": ["^generate"],
        "outputs": ["dist/**"],
        "cache": false,
        "persistent": true
      },
      "start": {
        "dependsOn": ["build"]
      },
      "lint": {
        "outputs": []
      },
      "lint:fix": {
        "cache": false,
        "outputs": []
      },
      "typecheck": {
        "dependsOn": ["^generate"],
        "outputs": []
      },
      "test": {
        "outputs": ["coverage/**"]
      }
    }
}
