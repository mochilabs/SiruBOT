generator client {
  provider = "prisma-client-js"
  output   = "../dist"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id                   String              @id
  volume               Int                 @default(10)
  textChannelId        String?
  voiceChannelId       String?
  enableController     Boolean             @default(true)
  sponsorBlockSegments String[]            @default([])
  djRoleId             String?
  repeat               String              @default("off")
  related              Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  history              GuildTrackHistory[]
}

model Track {
  id            String              @id
  title         String
  artist        String
  duration      Int
  thumbnail     String?
  url           String
  source        String
  totalPlays    Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  history       GuildTrackHistory[]
  userFavorites UserFavorite[]
}

model User {
  id        String              @id
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  history   GuildTrackHistory[]
  favorites UserFavorite[]
}

model GuildTrackHistory {
  id        String   @id @default(uuid())
  guildId   String
  trackId   String
  userId    String?
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([guildId, createdAt(sort: Desc)])
}

model UserFavorite {
  userId    String
  trackId   String
  createdAt DateTime @default(now())
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, trackId])
  @@index([trackId])
}
